# Required — create at https://aistudio.google.com/ (or use a Vertex AI key)
GEMINI_API_KEY=

# Optional — comma-separated fallback chain, newest first.
# Update when newer Gemini models are GA (e.g. add gemini-3.x-flash).
GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash

# Optional — free analyses per client/IP per hour
RATE_LIMIT_PER_HOUR=30

# Optional — protects GET /api/stats
ADMIN_TOKEN=

# Set to "false" to disable Firestore logging (it auto-enables on Google Cloud)
FIRESTORE_ENABLED=true
